# Supabase project URL (for frontend/API integrations)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase API keys
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Postgres connection string (from Supabase > Project Settings > Database)
# Example (pooled):
# postgres://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgres://postgres:postgres@localhost:5432/site_ops

JWT_SECRET=change-me
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
PORT=4000

# Set true only when you want the app to auto-create schema/tables
# In production Supabase, keep this false and run SQL migration scripts manually.
AUTO_INIT_DB=false
